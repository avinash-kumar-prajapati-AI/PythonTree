# Copy to .env and adjust. NEVER put real secrets in THIS file — it is
# committed to git. Real values belong in .env (gitignored) and in the
# Vercel project's environment variables.

# sqlite (default) | postgres | mysql — see src/server/db/README.md before swapping
DATABASE_DIALECT=sqlite

# Local dev: a file. Production: your Turso URL (libsql://...turso.io)
DATABASE_URL=file:./data/pythontree.db
# Required only for Turso:
DATABASE_AUTH_TOKEN=

# Admin login for /admin (defaults to "admin" in dev — change it!)
ADMIN_PASSWORD=change-me

# 32+ char secret for session cookies
SESSION_SECRET=please-generate-a-long-random-string-here
